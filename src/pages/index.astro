---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SUMMARY_PACKAGES } from "../lib/config";
import { formatTimestamp, listImageSummaries } from "../lib/image-data";

const images = listImageSummaries();
---

<BaseLayout title="Image Viewer">
  <section class="hero">
    <span class="hero__eyebrow">Local Fixture Mode</span>
    <h1>Published image builds, keyed by timestamp and package summary.</h1>
    <p>
      The landing page is driven by a checked-in global manifest that mirrors
      the future D1 index and points to one image JSON file per image.
    </p>
    <div class="meta-strip">
      <article class="stat">
        <span class="stat__label">Sample Images</span>
        <span class="stat__value">{images.length}</span>
      </article>
      <article class="stat">
        <span class="stat__label">Summary Packages</span>
        <span class="stat__value">{SUMMARY_PACKAGES.length}</span>
      </article>
      <article class="stat">
        <span class="stat__label">JSON Layers</span>
        <span class="stat__value">3</span>
      </article>
    </div>
  </section>

  <section class="panel">
    <h2 class="section-title">Available Images</h2>
    <p class="section-subtitle">
      The table is sorted newest-first and uses the simplified global manifest
      contract.
    </p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>Image name</th>
            <th>AMI ID</th>
            <th>Docker image</th>
            {SUMMARY_PACKAGES.map((packageName) => <th>{packageName}</th>)}
            <th>Details</th>
          </tr>
        </thead>
        <tbody>
          {images.map((image) => (
            <tr>
              <td>{formatTimestamp(image.timestamp)}</td>
              <td>
                <a class="image-link" href={`/images/${image.name}`}>
                  {image.name}
                </a>
              </td>
              <td class="mono">{image.amiId}</td>
              <td class="mono">{image.dockerImage}</td>
              {SUMMARY_PACKAGES.map((packageName) => (
                <td>{image.packageVersions[packageName] ?? "—"}</td>
              ))}
              <td>
                <a href={`/images/${image.name}`}>Open</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
