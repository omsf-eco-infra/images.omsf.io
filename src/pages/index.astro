---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SUMMARY_PACKAGES } from "../lib/config";
import { formatTimestamp, listImageSummaries } from "../lib/image-data";

const images = listImageSummaries();

function formatDate(timestamp: string): string {
  return timestamp.slice(0, 10);
}
---

<BaseLayout title="OMSF Machine Images">
  <section class="panel">
    <h1 class="section-title">All Images ({images.length})</h1>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="timestamp-column">Date</th>
            <th>Image name</th>
            <th>AMI ID</th>
            <th>Docker image</th>
            <th>Key Versions</th>
          </tr>
        </thead>
        <tbody>
          {images.map((image) => (
            <tr>
              <td
                class="timestamp-cell"
                title={formatTimestamp(image.timestamp)}
              >
                <time datetime={image.timestamp}>{formatDate(image.timestamp)}</time>
              </td>
              <td>
                <a class="image-link" href={`/images/${image.name}`}>
                  {image.name}
                </a>
              </td>
              <td class="mono">
                <span class="copy-field">
                  <span class="copy-field__value">{image.amiId}</span>
                  <button
                    class="copy-button"
                    type="button"
                    data-copy-value={image.amiId}
                    aria-label={`Copy AMI ID ${image.amiId}`}
                  >
                    Copy
                  </button>
                </span>
              </td>
              <td class="mono">
                <span class="copy-field copy-field--wide">
                  <span class="copy-field__value">{image.dockerImage}</span>
                  <button
                    class="copy-button"
                    type="button"
                    data-copy-value={image.dockerImage}
                    aria-label={`Copy Docker image URL ${image.dockerImage}`}
                  >
                    Copy
                  </button>
                </span>
              </td>
              <td>
                <ul class="summary-package-list">
                  {SUMMARY_PACKAGES.map((packageName) => (
                    <li>
                      <span class="summary-package-list__name">
                        {packageName}
                      </span>
                      <span class="summary-package-list__version">
                        {image.packageVersions[packageName] ?? "—"}
                      </span>
                    </li>
                  ))}
                </ul>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="mobile-image-list" aria-label="All images">
      {images.map((image) => (
        <article class="mobile-image-record">
          <header class="mobile-image-record__header">
            <a class="image-link" href={`/images/${image.name}`}>
              {image.name}
            </a>
            <time
              class="mobile-image-record__date"
              datetime={image.timestamp}
              title={formatTimestamp(image.timestamp)}
            >
              {formatDate(image.timestamp)}
            </time>
          </header>

          <div class="mobile-image-record__field">
            <span class="mobile-image-record__label">AMI ID</span>
            <span class="copy-field">
              <span class="copy-field__value mono">{image.amiId}</span>
              <button
                class="copy-button"
                type="button"
                data-copy-value={image.amiId}
                aria-label={`Copy AMI ID ${image.amiId}`}
              >
                Copy
              </button>
            </span>
          </div>

          <div class="mobile-image-record__field">
            <span class="mobile-image-record__label">Docker image</span>
            <span class="copy-field">
              <span class="copy-field__value mono">{image.dockerImage}</span>
              <button
                class="copy-button"
                type="button"
                data-copy-value={image.dockerImage}
                aria-label={`Copy Docker image URL ${image.dockerImage}`}
              >
                Copy
              </button>
            </span>
          </div>

          <div class="mobile-image-record__field">
            <span class="mobile-image-record__label">Key Versions</span>
            <ul class="summary-package-list">
              {SUMMARY_PACKAGES.map((packageName) => (
                <li>
                  <span class="summary-package-list__name">
                    {packageName}
                  </span>
                  <span class="summary-package-list__version">
                    {image.packageVersions[packageName] ?? "—"}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
