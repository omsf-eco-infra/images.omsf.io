---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { KEY_PACKAGES } from "../../lib/config";
import {
  buildSelectionIndex,
  filterPackagesByName,
  formatBuildDatetime,
  listAmiManifestRecords,
  listPlatformsForEnvironment,
  readArtifactFromUrl,
  resolveDefaultSelection,
} from "../../lib/ami-data";
import type { AmiManifestRecord, PackageRecord } from "../../lib/types";

export function getStaticPaths() {
  return listAmiManifestRecords().map((ami) => ({
    params: { name: ami.name },
    props: { ami },
  }));
}

interface Props {
  ami: AmiManifestRecord;
}

const { ami } = Astro.props as Props;
const defaultSelection = resolveDefaultSelection(ami);

if (!defaultSelection) {
  throw new Error(`AMI ${ami.name} has no environment/platform selections.`);
}

const initialSelection = ami.selections.find(
  (selection) =>
    selection.environment === defaultSelection.environment &&
    selection.platform === defaultSelection.platform,
);

if (!initialSelection) {
  throw new Error(`No artifact found for ${ami.name} default selection.`);
}

const initialArtifact = await readArtifactFromUrl(initialSelection.artifactUrl);
const selectionIndex = buildSelectionIndex(ami);
const initialPlatformOptions = listPlatformsForEnvironment(
  ami,
  initialArtifact.selection.environment,
);

const clientConfig = {
  initialArtifactUrl: initialSelection.artifactUrl,
  selectionIndex,
};

const initialPackages = filterPackagesByName(initialArtifact.packages, "");

function packageField(value: string | undefined): string {
  return value && value !== "" ? value : "—";
}
---

<BaseLayout title={`AMI ${ami.name}`}>
  <a class="back-link" href="/">← Back to AMI index</a>

  <section class="hero">
    <span class="hero__eyebrow">AMI Detail</span>
    <h1>{ami.name}</h1>
    <p>
      Selection data is fetched from static per-selection JSON artifacts so the
      UI already mirrors the future R2-backed detail flow.
    </p>
    <div class="meta-strip">
      <article class="stat">
        <span class="stat__label">AMI ID</span>
        <span class="stat__value mono">{ami.amiId}</span>
      </article>
      <article class="stat">
        <span class="stat__label">Build datetime</span>
        <span class="stat__value">{formatBuildDatetime(ami.buildDatetime)}</span>
      </article>
      <article class="stat">
        <span class="stat__label">Lockfile</span>
        <span class="stat__value">
          <a href={ami.lockfileUrl} download>
            Download raw fixture
          </a>
        </span>
      </article>
    </div>
  </section>

  <section class="panel">
    <h2 class="section-title">Selection controls</h2>
    <p class="section-subtitle">
      Environment and platform options are derived from the local manifest.
    </p>
    <div class="control-grid">
      <div class="control">
        <label for="environment-select">Environment</label>
        <select id="environment-select">
          {Object.keys(selectionIndex).map((environment) => (
            <option
              value={environment}
              selected={environment === initialArtifact.selection.environment}
            >
              {environment}
            </option>
          ))}
        </select>
      </div>
      <div class="control">
        <label for="platform-select">Platform</label>
        <select id="platform-select">
          {initialPlatformOptions.map((selection) => (
            <option
              value={selection.platform}
              selected={selection.platform === initialArtifact.selection.platform}
            >
              {selection.platform}
            </option>
          ))}
        </select>
      </div>
      <div class="control">
        <label for="package-filter">Package name filter</label>
        <input
          id="package-filter"
          type="search"
          placeholder="Filter package names"
          autocomplete="off"
        />
      </div>
    </div>
  </section>

  <section class="summary-grid">
    <article class="summary-card">
      <span class="summary-card__label">Current selection</span>
      <span class="summary-card__value" id="selection-label">
        {initialArtifact.selection.environment} / {initialArtifact.selection.platform}
      </span>
    </article>
    <article class="summary-card">
      <span class="summary-card__label">Package count</span>
      <span class="summary-card__value" id="package-count">
        {initialArtifact.summary.packageCount}
      </span>
    </article>
    {KEY_PACKAGES.map((packageName) => (
      <article class="summary-card">
        <span class="summary-card__label">{packageName}</span>
        <span class="summary-card__value" data-key-package={packageName}>
          {initialArtifact.summary.keyPackages[packageName] ?? "—"}
        </span>
      </article>
    ))}
  </section>

  <section class="panel">
    <h2 class="section-title">Dependency table</h2>
    <p class="status-line" id="package-status">
      Showing {initialPackages.length} of {initialArtifact.packages.length} packages
      for {initialArtifact.selection.environment} / {initialArtifact.selection.platform}.
    </p>
    <p class="empty-state" id="package-empty" hidden>
      No packages match the current filter.
    </p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Package</th>
            <th>Version</th>
            <th>Build</th>
            <th>Channel</th>
            <th>Kind</th>
          </tr>
        </thead>
        <tbody id="package-table-body">
          {initialPackages.map((pkg: PackageRecord) => (
            <tr>
              <td>{pkg.name}</td>
              <td>{pkg.version}</td>
              <td>{packageField(pkg.build)}</td>
              <td>{packageField(pkg.channel)}</td>
              <td>{packageField(pkg.sourceType)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <script
    is:inline
    define:vars={{ clientConfig, initialArtifact, keyPackages: [...KEY_PACKAGES] }}
  >
    const environmentSelect = document.querySelector("#environment-select");
    const platformSelect = document.querySelector("#platform-select");
    const packageFilter = document.querySelector("#package-filter");
    const packageStatus = document.querySelector("#package-status");
    const packageEmpty = document.querySelector("#package-empty");
    const packageBody = document.querySelector("#package-table-body");
    const packageCount = document.querySelector("#package-count");
    const selectionLabel = document.querySelector("#selection-label");

    if (
      !(environmentSelect instanceof HTMLSelectElement) ||
      !(platformSelect instanceof HTMLSelectElement) ||
      !(packageFilter instanceof HTMLInputElement) ||
      !(packageStatus instanceof HTMLParagraphElement) ||
      !(packageEmpty instanceof HTMLParagraphElement) ||
      !(packageBody instanceof HTMLTableSectionElement) ||
      !(packageCount instanceof HTMLElement) ||
      !(selectionLabel instanceof HTMLElement)
    ) {
      throw new Error("Detail page controls could not be initialized.");
    }

    const keyPackageNodes = Object.fromEntries(
      keyPackages.map((packageName) => [
        packageName,
        document.querySelector(`[data-key-package="${packageName}"]`),
      ]),
    );

    const artifactCache = new Map([[clientConfig.initialArtifactUrl, initialArtifact]]);
    let currentArtifact = initialArtifact;

    function formatCell(value) {
      return value && value !== "" ? value : "—";
    }

    function renderPlatformOptions(environment, selectedPlatform) {
      const platformOptions = clientConfig.selectionIndex[environment] ?? [];
      platformSelect.replaceChildren();

      for (const option of platformOptions) {
        const node = document.createElement("option");
        node.value = option.platform;
        node.textContent = option.platform;
        node.selected = option.platform === selectedPlatform;
        platformSelect.append(node);
      }

      if (!platformOptions.some((option) => option.platform === selectedPlatform)) {
        platformSelect.value = platformOptions[0]?.platform ?? "";
      }
    }

    function renderPackages() {
      const query = packageFilter.value.trim().toLowerCase();
      const packages =
        query === ""
          ? currentArtifact.packages
          : currentArtifact.packages.filter((pkg) =>
              pkg.name.toLowerCase().includes(query),
            );

      packageBody.replaceChildren();
      packageEmpty.classList.remove("error-state");

      if (packages.length === 0) {
        packageEmpty.hidden = false;
        packageEmpty.textContent =
          query === ""
            ? `No packages are available for ${currentArtifact.selection.environment} / ${currentArtifact.selection.platform}.`
            : `No packages match "${packageFilter.value.trim()}" in ${currentArtifact.selection.environment} / ${currentArtifact.selection.platform}.`;
        packageStatus.textContent = `Showing 0 of ${currentArtifact.packages.length} packages for ${currentArtifact.selection.environment} / ${currentArtifact.selection.platform}.`;
        return;
      }

      packageEmpty.hidden = true;
      packageStatus.textContent = `Showing ${packages.length} of ${currentArtifact.packages.length} packages for ${currentArtifact.selection.environment} / ${currentArtifact.selection.platform}.`;

      for (const pkg of packages) {
        const row = document.createElement("tr");
        const values = [
          pkg.name,
          pkg.version,
          formatCell(pkg.build),
          formatCell(pkg.channel),
          formatCell(pkg.sourceType),
        ];

        for (const value of values) {
          const cell = document.createElement("td");
          cell.textContent = value;
          row.append(cell);
        }

        packageBody.append(row);
      }
    }

    function renderArtifact(artifact) {
      currentArtifact = artifact;
      environmentSelect.value = artifact.selection.environment;
      renderPlatformOptions(artifact.selection.environment, artifact.selection.platform);
      selectionLabel.textContent = `${artifact.selection.environment} / ${artifact.selection.platform}`;
      packageCount.textContent = `${artifact.summary.packageCount}`;

      for (const packageName of keyPackages) {
        keyPackageNodes[packageName].textContent =
          artifact.summary.keyPackages[packageName] ?? "—";
      }

      renderPackages();
    }

    async function loadArtifact(artifactUrl) {
      if (artifactCache.has(artifactUrl)) {
        return artifactCache.get(artifactUrl);
      }

      const response = await fetch(artifactUrl);

      if (!response.ok) {
        throw new Error(`Failed to load ${artifactUrl}`);
      }

      const artifact = await response.json();
      artifactCache.set(artifactUrl, artifact);
      return artifact;
    }

    async function syncSelection() {
      const environment = environmentSelect.value;
      const platformOptions = clientConfig.selectionIndex[environment] ?? [];

      if (platformOptions.length === 0) {
        packageBody.replaceChildren();
        packageEmpty.hidden = false;
        packageEmpty.classList.remove("error-state");
        packageEmpty.textContent = `No package artifacts are available for ${environment}.`;
        packageStatus.textContent = `No artifacts available for ${environment}.`;
        return;
      }

      const requestedPlatform = platformSelect.value;
      const nextSelection =
        platformOptions.find((option) => option.platform === requestedPlatform) ??
        platformOptions[0];

      renderPlatformOptions(environment, nextSelection.platform);
      packageStatus.textContent = `Loading ${environment} / ${nextSelection.platform}…`;

      try {
        const artifact = await loadArtifact(nextSelection.artifactUrl);
        renderArtifact(artifact);
      } catch (error) {
        packageBody.replaceChildren();
        packageEmpty.hidden = false;
        packageEmpty.classList.add("error-state");
        packageEmpty.textContent = `Could not load ${environment} / ${nextSelection.platform}.`;
        packageStatus.textContent = `Failed to load ${environment} / ${nextSelection.platform}.`;
        console.error(error);
      }
    }

    environmentSelect.addEventListener("change", () => {
      const nextOptions = clientConfig.selectionIndex[environmentSelect.value] ?? [];
      renderPlatformOptions(environmentSelect.value, nextOptions[0]?.platform ?? "");
      void syncSelection();
    });

    platformSelect.addEventListener("change", () => {
      void syncSelection();
    });

    packageFilter.addEventListener("input", () => {
      packageEmpty.classList.remove("error-state");
      renderPackages();
    });

    renderArtifact(initialArtifact);
  </script>
</BaseLayout>
